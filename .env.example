# Environment variables for Quantum Werewolf
# Copy this file to .env and adjust values as needed

# Application Settings
DEBUG=false
PORT=8000
HOST=0.0.0.0
PUBLIC_HOST=localhost:8000
USE_HTTPS=false
CORS_ORIGINS=*

# Database (if using PostgreSQL)
DATABASE_URL=postgresql://qw_user:qw_password@quantum-werewolf-db:5432/quantum_werewolf
SQLALCHEMY_ECHO=false

# Redis (if using for caching/sessions)
REDIS_URL=redis://quantum-werewolf-redis:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/quantum-werewolf.log

# Docker Registry (for Jenkins)
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# Jenkins (if using Jenkins)
JENKINS_URL=http://jenkins:8080
JENKINS_TOKEN=your_jenkins_token

# Security
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Game Settings
MAX_PLAYERS=20
MAX_GAME_DURATION=3600
GAME_TIMEOUT=300

